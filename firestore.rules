rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /userMappings/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null;
    }
    match /superadmin/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }
    match /companies/{companyId} {
      allow read: if request.auth != null && (
        exists(/databases/$(database)/documents/superadmin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid))
      );
      allow create, update: if exists(/databases/$(database)/documents/superadmin/$(request.auth.uid));
    }
    match /companies/{companyId}/users/{userId} {
      allow read: if request.auth != null && (
        exists(/databases/$(database)/documents/superadmin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid))
      );
      allow write: if request.auth != null && (
        exists(/databases/$(database)/documents/superadmin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid))
      );
    }
    match /companies/{companyId}/{subcollection}/{docId} {
      allow read, write: if request.auth != null && (
        exists(/databases/$(database)/documents/superadmin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid))
      );
    }
    match /config/askmike/transcripts/{transcriptId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
                  && (resource.data.userId == request.auth.uid
                      || exists(/databases/$(database)/documents/superadmin/$(request.auth.uid)));
    }
    match /config/askmike/{subcollection}/{docId} {
      allow read: if request.auth != null;
      allow write: if exists(/databases/$(database)/documents/superadmin/$(request.auth.uid));
    }
  }
}
